# ---------------------------------------------------------------------------
# Foota Jerseys — environment variables
#
# The storefront runs out-of-the-box with realistic MOCK data when these are
# unset. Fill them in to switch to a live Shopify Storefront API with no code
# changes.
# ---------------------------------------------------------------------------

# Your Shopify store domain, e.g. foota-jerseys.myshopify.com (no protocol).
SHOPIFY_STORE_DOMAIN=

# Storefront API access token.
# Shopify admin → Settings → Apps and sales channels → Develop apps →
# create/select an app → Storefront API → install → copy the access token.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Storefront API version (YYYY-MM). Use a recent stable version.
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# Admin API access token — only needed to run the one-shot maintenance scripts
# (scripts/seed-shopify.mjs, scripts/brand-checkout.mjs), never by the app at
# runtime. Same Develop-apps flow as above, but grant Admin API scopes:
# write_products / write_publications (seed) and write_checkout_branding_settings
# (brand:checkout, which additionally needs the Plus or dev-store plan).
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Variant GID of the "Name & Number Printing" add-on product. A customised
# jersey is added with a paired line for this variant so the printing upcharge
# is collected at Shopify's hosted checkout. Leave unset to degrade gracefully
# (the name/number is captured but the upcharge is not charged).
# Format: gid://shopify/ProductVariant/<id>
SHOPIFY_CUSTOMISATION_VARIANT_ID=

# Public site URL — used for SEO metadata, Open Graph and the sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret to guard the /api/revalidate webhook route. Generate with
# `openssl rand -hex 32`. Shopify product/collection webhooks must call
# /api/revalidate?secret=<this value>.
SHOPIFY_REVALIDATION_SECRET=
